HF_TOKEN=
HF_HUB_ENABLE_HF_TRANSFER=1
RUNPOD_SERVERLESS=false
COMFYUI_API_URL=http://127.0.0.1:8188

PERSISTENT_ROOT=/runpod-volume
PERSIST_MODELS_SUBDIR=models
